import os
import json
import random
import requests
import jdatetime
from datetime import datetime
from apscheduler.schedulers.blocking import BlockingScheduler
TOKEN = os.getenv("BOT_TOKEN")
CHAT_ID = os.getenv("CHAT_ID")
BASE_DIR = os.path.dirname(os.path.abspath(__file__))
CITIES_FILE = os.path.join(BASE_DIR, "cities.json")
FACTS_FILE = os.path.join(BASE_DIR, "facts.json")
CITY_INDEX_FILE = os.path.join(BASE_DIR, "city_index.txt")
FACT_INDEX_FILE = os.path.join(BASE_DIR, "fact_index.txt")
IMAGES_DIR = os.path.join(BASE_DIR, "images")
print("BAKUCHI BOT RUNNING")
# ---------------- RANDOM WEATHER TEXTS ----------------
weather_texts = [
    "💬 امروز باکو حال و هوای آرومی داره 😄",
    "💬 هوای امروز برای گشت و گذار خیلی خوبه ✨",
    "💬 یه روز دیگه در باکوی زیبا 🇦🇿",
    "💬 امروز خیابون‌های باکو حسابی دیدنی‌ان 😍",
    "💬 اگه الان باکویی، از هوا لذت ببر 🌤",
    "💬 امروز وقت یه چای داغ کنار ساحله ☕",
    "💬 باکو امروز خوش آب و هواست 😎",
]
# ---------------- SEND MESSAGE ----------------
def send_message(message):
    url = f"https://api.telegram.org/bot{TOKEN}/sendMessage"
    data = {
        "chat_id": CHAT_ID,
        "text": message,
        "parse_mode": "HTML"
    }
    r = requests.post(url, data=data)
    print("SEND MESSAGE:")
    print(r.text)
# ---------------- WEATHER ----------------
def send_weather():
    try:
        weather_data = requests.get(
            "https://wttr.in/Baku?format=j1",
            timeout=20
        ).json()
        current = weather_data["current_condition"][0]
        temp = current["temp_C"]
        humidity = current["humidity"]
        wind = current["windspeedKmph"]
        desc = current["weatherDesc"][0]["value"]
        emoji = "🌤"
        desc_lower = desc.lower()
        if "rain" in desc_lower:
            emoji = "🌧"
        elif "cloud" in desc_lower:
            emoji = "☁️"
        elif "sun" in desc_lower or "clear" in desc_lower:
            emoji = "☀️"
        today_shamsi = jdatetime.datetime.now().strftime("%d %B %Y")
        today_miladi = datetime.now().strftime("%d %B %Y")
        random_text = random.choice(weather_texts)
        message = f"""
{emoji} <b>باکوچی | وضعیت هوای باکو</b>
📅 شمسی: {today_shamsi}
📆 میلادی: {today_miladi}
🌡 دما: {temp}°C
💨 باد: {wind} km/h
💧 رطوبت: {humidity}%
🌦 وضعیت: {desc}
{random_text}
@bakuchi_official_channel
"""
        send_message(message)
    except Exception as e:
        print("WEATHER ERROR:")
        print(e)
# ---------------- LOAD JSON ----------------
def load_json(file_path):
    try:
        print("READING FILE:", file_path)
        with open(file_path, "rb") as f:
            raw = f.read()
        text = raw.decode("utf-8-sig")
        data = json.loads(text)
        print("JSON LOADED SUCCESSFULLY")
        return data
    except Exception as e:
        print("JSON ERROR:")
        print(e)
        return []
# ---------------- GET NEXT ITEM ----------------
def get_next_item(json_file, index_file):
    items = load_json(json_file)
    if not items:
        return None
    if not os.path.exists(index_file):
        with open(index_file, "w") as f:
            f.write("0")
    with open(index_file, "r") as f:
        index_text = f.read().strip()
    if not index_text.isdigit():
        index = 0
    else:
        index = int(index_text)
    # اگر تموم شد از اول شروع کن
    if index >= len(items):
        index = 0
    item = items[index]
    with open(index_file, "w") as f:
        f.write(str(index + 1))
    return item
# ---------------- CITY POST ----------------
def send_city():
    try:
        city = get_next_item(
            CITIES_FILE,
            CITY_INDEX_FILE
        )
        if city is None:
            print("NO CITY FOUND")
            return
        caption = city["text"]
        image_path = os.path.join(
            IMAGES_DIR,
            city["image"]
        )
        print("IMAGE PATH:", image_path)
        if not os.path.exists(image_path):
            print("IMAGE NOT FOUND")
            return
        url = f"https://api.telegram.org/bot{TOKEN}/sendPhoto"
        with open(image_path, "rb") as photo:
            files = {
                "photo": photo
            }
            data = {
                "chat_id": CHAT_ID,
                "caption": caption,
                "parse_mode": "HTML"
            }
            r = requests.post(
                url,
                data=data,
                files=files
            )
            print("CITY SENT:")
            print(r.text)
    except Exception as e:
        print("CITY ERROR:")
        print(e)
# ---------------- FACT POST ----------------
def send_fact():
    try:
        fact = get_next_item(
            FACTS_FILE,
            FACT_INDEX_FILE
        )
        if fact is None:
            print("NO FACT FOUND")
            return
        # اگر fact دیکشنری بود
        if isinstance(fact, dict):
            fact_text = fact.get("text", "دانستنی موجود نیست")
        else:
            fact_text = str(fact)
        message = f"""
🧠 <b>دانستنی امروز</b>
{fact_text}
@bakuchi_official_channel
"""
        send_message(message)
        print("FACT SENT SUCCESSFULLY")
    except Exception as e:
        print("FACT ERROR:")
        print(e)
# ---------------- SCHEDULER ----------------
scheduler = BlockingScheduler(timezone="Asia/Baku")
# 9 صبح باکو
scheduler.add_job(
    send_weather,
    "cron",
    hour=9,
    minute=0
)
# 3 عصر باکو
scheduler.add_job(
    send_city,
    "cron",
    hour=15,
    minute=0
)
# 9 شب باکو
scheduler.add_job(
    send_fact,
    "cron",
    hour=21,
    minute=0
)
print("SCHEDULER STARTED")
scheduler
